{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "rangeStart": 0,
  "rangeEnd": null,
  "requirePragma": false,
  "insertPragma": false,
  "proseWrap": "preserve",
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "**/dist/",
    "**/lib/",
    "**/scripts/",
    "**/upload/",
    "**/uploads/",
    "**/files/",
    "**/tmp/",
    "**/temp/",
    "**/node_modules/",
    "**/*.example",
    "**/coverage/",
    "**/*.snap",
    ".idea",
    ".vscode"
  ]
}
