{
  "name": "examples",
  "version": "6.2.1",
  "private": true,
  "scripts": {
    "basic": "tsx watch -r dotenv/config express-basic",
    "express": "tsx watch -r dotenv/config express",
    "redis": "tsx watch -r dotenv/config express-redis",
